generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("candidate") // candidate | employer | admin
  createdAt    DateTime @default(now())

  candidateProfile CandidateProfile?
  company          Company?
  flags            Flag[]
}

model CandidateProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  name         String
  headline     String?
  location     String?
  skills       String   @default("[]") // JSON array
  resumeFileId String?
  portfolioUrl String?
  linkedinUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Company {
  id          String   @id @default(cuid())
  ownerUserId String   @unique
  name        String
  logo        String?
  description String?
  website     String?
  status      String   @default("active") // active | suspended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  jobs  Job[]
}

model Job {
  id             String   @id @default(cuid())
  companyId      String
  title          String
  description    String
  location       String?
  employmentType String? // full-time | part-time | contract | internship
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String   @default("USD")
  tags           String   @default("[]") // JSON array
  status         String   @default("draft") // draft | published | closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id            String   @id @default(cuid())
  jobId         String
  candidateId   String
  resumeFileId  String?
  coverNote     String?
  status        String   @default("new") // new | reviewing | interview | offer | closed
  statusHistory String   @default("[]") // JSON array of {from, to, timestamp, note}
  internalNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model File {
  id        String   @id @default(cuid())
  filename  String
  mimetype  String
  data      Bytes
  size      Int
  createdAt DateTime @default(now())
}

model Flag {
  id           String   @id @default(cuid())
  targetType   String // job | company
  targetId     String
  reason       String
  status       String   @default("open") // open | resolved
  reportedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reportedBy User? @relation(fields: [reportedById], references: [id], onDelete: SetNull)
}
